#include <SPI.h>
#include <MFRC522.h>
#include <LiquidCrystal.h>
#include <Servo.h>
#include <Keypad.h>

// LCD Pin Yapılandırması
LiquidCrystal lcd(13, 12, 11, 10, 7, 6);

#define SS_PIN 53
#define RST_PIN 5 
MFRC522 rfid(SS_PIN, RST_PIN);

Servo kapi;

// Keypad Tuş Haritası ve Pin Tanımlamaları
const byte ROWS = 4;
const byte COLS = 4;
char keys[ROWS][COLS] = {
  {'1','2','3','A'}, {'4','5','6','B'},
  {'7','8','9','C'}, {'*','0','#','D'}
};
byte rowPins[ROWS] = {22, 23, 24, 25}; 
byte colPins[COLS] = {26, 27, 28, 29}; 
Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// LED ve Buzzer Pin Tanımları
const int yesilLed = 44;
const int kirmiziLed = 45;
const int buzzer = 8;

void setup() {
  lcd.begin(16, 2);
  lcd.print("GUVENLIK AKTIF");
  
  SPI.begin();
  rfid.PCD_Init();
  kapi.attach(9);
  kapi.write(0);
  
  pinMode(yesilLed, OUTPUT);
  pinMode(kirmiziLed, OUTPUT);
  pinMode(buzzer, OUTPUT);
  
  delay(1500);
  temizle(); // Temel arayüz hazırlığı
}
